{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "MongoDB": "mongodb://user:pass@localhost:27017"
  },
  "AllowedHosts": "*",
  "AkkaSettings": {
    "ActorSystemName": "AkkaWebApi",
    "UseClustering": true,
    "RemoteOptions": {
      "HostName": "0.0.0.0",
      "Port": 8081
    },
    "ClusterOptions": {
      "Roles": [
        "root",
        "root-compute",
        "compute"
      ]
    },
    "ShardOptions": {
      "StateStoreMode": "DData",
      "RememberEntities": false,
      "Role": "root"
    },
    "AkkaManagementOptions": {
      "Enabled": true,
      "Hostname": "localhost",
      "PortName": "management",
      "ServiceName": "akka-management",
      "RequiredContactPointsNr": 1,
      "DiscoveryMethod": "Config"
    },
    "PersistenceMode": "InMemory"
  },
  "MongoDB": {
    "DatabaseName": "test-db"
  }
}
